DJANGO_ENV=local
DJANGO_SECRET_KEY=replace-this-with-at-least-50-random-characters
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=media
SERVE_MEDIA_FILES=true
POSTGRES_DB=mindrise
POSTGRES_USER=mindrise
POSTGRES_PASSWORD=change-this-local-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mindrise:change-this-local-password@localhost:5432/mindrise
DATABASE_CONN_MAX_AGE=600
DATABASE_CONN_HEALTH_CHECKS=true
DATABASE_DISABLE_SERVER_SIDE_CURSORS=false
DATABASE_SSL_REQUIRE=false
TRUST_PROXY_SSL_HEADER=false
USE_X_FORWARDED_HOST=false
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7
SECURE_SSL_REDIRECT=false
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@mindrisewellness.org
RESEND_API_URL=https://api.resend.com
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL="MindRise <no-reply@mindrisewellness.org>"
RESEND_REPLY_TO_EMAIL=
RESEND_TIMEOUT_SECONDS=8
CONTACT_RECIPIENT_EMAIL=mindriserwanda@gmail.com
CONTACT_EMAIL_SUBJECT_PREFIX="[MindRise Contact]"
EMAIL_VERIFICATION_CODE_TTL_MINUTES=15
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
AI_INSIGHTS_PROVIDER=local
AI_INSIGHTS_ENDPOINT=
AI_INSIGHTS_API_KEY=
AI_INSIGHTS_TIMEOUT_SECONDS=8
AI_INSIGHTS_INCLUDE_NOTES=false
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_CHATBOT_MODEL=gpt-5.5
OPENAI_CHATBOT_TIMEOUT_SECONDS=20
OPENAI_CHATBOT_MAX_OUTPUT_TOKENS=500
OPENAI_CHATBOT_REASONING_EFFORT=low
OPENAI_CHATBOT_VERBOSITY=low
